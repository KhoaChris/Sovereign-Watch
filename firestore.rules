rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    function ownsConversation(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasValidConversationShape(userId) {
      return request.resource.data.keys().hasOnly([
        "assignedAdminEmail",
        "assignedAdminId",
        "assignedAdminName",
        "archivedAt",
        "archivedByAdminId",
        "archivedByAdminName",
        "createdAt",
        "id",
        "lastAdminMessageAt",
        "lastBotMessageAt",
        "lastCustomerMessageAt",
        "lastMessage",
        "lastMessageAt",
        "messageCount",
        "mode",
        "moderationFlagCount",
        "status",
        "unreadForAdmin",
        "unreadForUser",
        "updatedAt",
        "userEmail",
        "userId",
        "userName"
      ])
      && request.resource.data.userId == userId
      && request.resource.data.status in ["open", "closed", "archived"]
      && request.resource.data.mode in ["human", "bot"];
    }

    function hasValidMessageShape(userId) {
      return request.resource.data.keys().hasOnly([
        "body",
        "channel",
        "conversationId",
        "createdAt",
        "id",
        "moderationFlags",
        "senderId",
        "senderName",
        "senderRole",
        "suggestions"
      ])
      && request.resource.data.body is string
      && request.resource.data.body.size() > 0
      && request.resource.data.body.size() <= 1000
      && request.resource.data.channel in ["admin", "ai"]
      && request.resource.data.conversationId == userId
      && request.resource.data.createdAt == request.time
      && request.resource.data.moderationFlags is list
      && request.resource.data.senderId is string
      && request.resource.data.senderName is string
      && request.resource.data.senderRole in ["admin", "bot", "user"]
      && request.resource.data.suggestions is list
      && (
        (isAdmin()
          && request.resource.data.senderRole == "admin"
          && request.resource.data.channel == "admin") ||
        (ownsConversation(userId)
          && request.resource.data.senderRole == "user") ||
        (ownsConversation(userId)
          && request.resource.data.senderRole == "bot"
          && request.resource.data.channel == "ai")
      );
    }

    match /supportPresence/admin {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /supportConversations/{userId} {
      allow read: if isAdmin() || ownsConversation(userId);
      allow create, update: if (isAdmin() || ownsConversation(userId))
        && hasValidConversationShape(userId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAdmin() || ownsConversation(userId);
        allow create: if (isAdmin() || ownsConversation(userId))
          && hasValidMessageShape(userId);
        allow update: if false;
        allow delete: if isAdmin() || ownsConversation(userId);
      }
    }
  }
}
